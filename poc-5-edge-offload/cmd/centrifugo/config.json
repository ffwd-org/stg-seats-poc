{
  "token_hmac_secret_key": "poc-secret-key-for-jwt",
  "api_key": "poc-api-key",
  "admin": false,
  "prometheus": true,
  "address": "0.0.0.0",
  "port": 8000,
  "internal_port": 9000,
  "namespaces": [
    {
      "name": "events",
      "history_size": 0,
      "history_ttl": "0s",
      "force_push_join_leave": false,
      "allow_subscribe_for_client": true
    }
  ],
  "client_channel_limit": 1,
  "client_queue_max_size": 1048576,
  "websocket": {
    "read_buffer_size": 512,
    "write_buffer_size": 512
  }
}
