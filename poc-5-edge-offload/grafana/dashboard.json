      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "centrifugo_unique_clients_total", "legendFormat": "clients", "refId": "A"}],
      "title": "Active WS Connections",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Messages published per second",
      "fieldConfig": {"defaults": {"color": {"fixedColor": "green", "mode": "fixed"}, "unit": "ops", "min": 0}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "id": 3,
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(centrifugo_messages_published_total[5s])", "legendFormat": "pub/sec", "refId": "A"}],
      "title": "Messages Published/sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "E2E fan-out latency — Centrifugo publish to client receipt",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "s", "min": 0}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "id": 4,
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.50, rate(centrifugo_publish_latency_seconds_bucket[10s]))", "legendFormat": "p50", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.99, rate(centrifugo_publish_latency_seconds_bucket[10s]))", "legendFormat": "p99", "refId": "B"}
      ],
      "title": "Publish Latency (p50/p99)",
      "type": "timeseries"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 5, "title": "Comparison with POC 2 (Go WS)", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Centrifugo memory — should be ~2-3KB/connection (vs Go's 30-50KB)",
      "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "bytes", "min": 0}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 6,
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "centrifugo_memory_bytes", "legendFormat": "RSS", "refId": "A"}],
      "title": "Centrifugo RSS Memory",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Memory per connection — Go WS vs Centrifugo comparison",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "bytes", "min": 0}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 7,
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "centrifugo_memory_bytes / centrifugo_unique_clients_total", "legendFormat": "KB/conn (Centrifugo)", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "go_memstats_rss_bytes{poc=\"poc2\"} / poc2_active_connections", "legendFormat": "KB/conn (Go WS)", "refId": "B"}
      ],
      "title": "Memory per Connection — Centrifugo vs Go WS",
      "type": "timeseries"
    }
