      "title": "Valkey CPU %",
      "type": "timeseries"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 4, "title": "End-to-End Latency", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "E2E latency: HTTP response to intent execution — p50/p95/p99",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 15, "lineWidth": 2, "showPoints": "never"},
          "unit": "s",
          "min": 0
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*p50.*"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*p95.*"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*p99.*"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 5,
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.50, rate(poc_e2e_latency_seconds_bucket[10s]))", "legendFormat": "p50", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.95, rate(poc_e2e_latency_seconds_bucket[10s]))", "legendFormat": "p95", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.99, rate(poc_e2e_latency_seconds_bucket[10s]))", "legendFormat": "p99", "refId": "C"}
      ],
      "title": "E2E Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Queue backlog depth — Redpanda consumer lag, NATS pending, Valkey XLEN",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "none", "min": 0}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 6,
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "queue_depth", "legendFormat": "queue depth", "refId": "A"}
      ],
      "title": "Queue Depth (Backlog)",
      "type": "timeseries"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 7, "title": "Reliability", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Error rate — should be near zero for valid intent processing",
      "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "unit": "percentunit", "min": 0, "max": 1}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 8,
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(poc_ops_total{poc=\"poc4\",result=\"error\"}[10s]) / (rate(poc_ops_total{poc=\"poc4\",result=\"error\"}[10s]) + rate(poc_ops_total{poc=\"poc4\",result=\"ok\"}[10s]))", "legendFormat": "error rate", "refId": "A"}
      ],
      "title": "Error Rate",
      "type": "timeseries"
    }
