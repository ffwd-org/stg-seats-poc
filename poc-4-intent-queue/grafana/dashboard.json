      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(poc_ops_total{poc=\"poc4\",result=\"ok\"}[5s])", "legendFormat": "ops/sec", "refId": "A"}
      ],
      "title": "Intent Processing Rate (ops/sec)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Valkey CPU — direct vs queued path comparison",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "percent", "min": 0, "max": 100}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "valkey_cpu_percent", "legendFormat": "Valkey CPU %", "refId": "A"}
