      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Intents processed per second — Direct vs Redpanda vs NATS vs Valkey Streams",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "lineWidth": 2, "showPoints": "never"},
