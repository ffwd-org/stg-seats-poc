{
  "annotations": {"list": [{"builtIn": 1, "enable": true, "hide": true, "name": "Annotations & Alerts", "type": "dashboard"}]},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1, "title": "Throughput", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Best-available seat search ops/sec",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "orange", "mode": "fixed"},
          "unit": "ops",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(poc_ops_total{poc=\"poc3\",result=\"ok\"}[5s])",
          "legendFormat": "ops/sec",
          "refId": "A"
        }
      ],
      "title": "Best-Available OPS/sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Active Lua script workers",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "yellow", "mode": "fixed"},
          "unit": "none",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "poc_active_workers{poc=\"poc3\"}",
          "legendFormat": "workers",
          "refId": "A"
        }
      ],
      "title": "Active Workers",
      "type": "timeseries"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 4, "title": "Latency", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Best-available search latency p50/p95/p99",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 15, "lineWidth": 2, "showPoints": "never"},
          "unit": "s",
          "min": 0
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*p50.*"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*p95.*"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*p99.*"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 5,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, rate(poc_latency_seconds_bucket{poc=\"poc3\",operation=\"best-avail\"}[10s]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, rate(poc_latency_seconds_bucket{poc=\"poc3\",operation=\"best-avail\"}[10s]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, rate(poc_latency_seconds_bucket{poc=\"poc3\",operation=\"best-avail\"}[10s]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Best-Available Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 6, "title": "Reliability", "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Error rate — seat unavailable or script errors",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "red", "mode": "fixed"},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 7,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(poc_ops_total{poc=\"poc3\",result=\"error\"}[10s]) / (rate(poc_ops_total{poc=\"poc3\",result=\"error\"}[10s]) + rate(poc_ops_total{poc=\"poc3\",result=\"ok\"}[10s]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["stg-seats", "poc3", "best-available"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timezone": "browser",
  "title": "POC 3 — Best Available Lua Search",
  "uid": "poc3-best-available",
  "version": 1
}
