{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "Connection Ramp",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Active WebSocket connections over time",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "orange", "mode": "fixed"},
          "unit": "none",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "poc2_active_connections",
          "legendFormat": "connections",
          "refId": "A"
        }
      ],
      "title": "Active WebSocket Connections",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Go runtime goroutine count — spikes during broadcast",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "yellow", "mode": "fixed"},
          "unit": "none",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "poc2_goroutine_count",
          "legendFormat": "goroutines",
          "refId": "A"
        }
      ],
      "title": "Goroutine Count",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 4,
      "panels": [],
      "title": "Broadcast Performance",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Time to fan out a broadcast to all connections (p50, p95, p99)",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "s",
          "min": 0
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*p50.*"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*p95.*"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*p99.*"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 5,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, rate(poc2_broadcast_duration_seconds_bucket[10s]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, rate(poc2_broadcast_duration_seconds_bucket[10s]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, rate(poc2_broadcast_duration_seconds_bucket[10s]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Broadcast Fan-out Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total broadcast operations over time",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "orange", "mode": "fixed"},
          "unit": "none"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 6,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(poc2_broadcast_total[10s])",
          "legendFormat": "broadcasts/sec",
          "refId": "A"
        }
      ],
      "title": "Broadcast Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 7,
      "panels": [],
      "title": "Memory & GC",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "RSS memory of Go process — look for growth during connection ramp",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "blue", "mode": "fixed"},
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 8,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "process_resident_memory_bytes{job=\"poc2\"}",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "title": "RSS Memory (Go process)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "GC pause nanoseconds — spikes indicate GC pressure from 250K connections",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "red", "mode": "fixed"},
          "unit": "ns",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 9,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(go_gc_pause_seconds_sum{poc=\"poc2\"}[10s])",
          "legendFormat": "GC pause/s",
          "refId": "A"
        }
      ],
      "title": "GC Pause Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total dropped WebSocket connections over time",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "red", "mode": "fixed"},
          "unit": "none",
          "min": 0
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 27},
      "id": 10,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(poc2_dropped_connections_total[10s])",
          "legendFormat": "dropped/sec",
          "refId": "A"
        }
      ],
      "title": "Dropped Connections",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["stg-seats", "poc2", "websocket"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "POC 2 — Go WebSocket Fan-out",
  "uid": "poc2-websocket-fanout",
